---
import BaseLayout from "../layouts/BaseLayout.astro";
import { frontmatter } from "../content/profile.md";
import envelopeIcon from "@phosphor-icons/core/regular/envelope-simple.svg?raw";
import githubIcon from "@phosphor-icons/core/regular/github-logo.svg?raw";
import linkedinIcon from "@phosphor-icons/core/regular/linkedin-logo.svg?raw";
import xIcon from "@phosphor-icons/core/regular/x-logo.svg?raw";

const { name, title, summary, seoDescription, links, roles } = frontmatter;
const pageTitle = `${name} - ${title}`;
const iconByLabel = {
  GitHub: githubIcon,
  Twitter: xIcon,
  X: xIcon,
  LinkedIn: linkedinIcon,
  Email: envelopeIcon
};

const withIconClass = (svg, className) => svg.replace("<svg ", `<svg class="${className}" aria-hidden="true" focusable="false" `);
const withIconGradient = (svg, id) =>
  withIconClass(svg, "contact-icon")
    .replace("<svg ", `<svg style="--contact-icon-gradient: url(#${id});" `)
    .replace('fill="currentColor"', 'fill="currentColor"')
    .replace(/><path([^>]*)\/>/, `><defs><linearGradient id="${id}" x1="0%" y1="100%" x2="100%" y2="0%"><stop class="contact-icon-stop-1" offset="0%"/><stop class="contact-icon-stop-2" offset="45%"/><stop class="contact-icon-stop-3" offset="100%"/></linearGradient><mask id="${id}-mask" maskUnits="userSpaceOnUse" x="-16" y="-16" width="288" height="288"><path$1 fill="white"/></mask></defs><path class="contact-icon-base-path"$1/><rect class="contact-icon-gradient-fill" x="-16" y="-16" width="288" height="288" fill="url(#${id})" mask="url(#${id}-mask)"/>`);
---

<BaseLayout title={pageTitle} description={seoDescription ?? summary}>
  <main class="mx-auto w-full max-w-[42.5rem] px-3 py-8 md:px-8 md:py-16">
    <header class="flex min-h-[38vh] flex-col justify-center pb-6 pt-2 md:min-h-[46vh] md:pb-10 md:pt-4" aria-labelledby="intro-title">
      <a class="home-logo-link mb-9 block h-10 w-10 text-ink md:mb-14" href="/" aria-label="Ali Salem home">
        <svg class="h-full w-full" viewBox="0 0 34 34" role="img" aria-hidden="true" focusable="false">
          <defs>
            <linearGradient id="home-logo-gradient" x1="0%" y1="100%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="oklch(64.1% 0.275 312.9)">
                <animate attributeName="stop-color" values="oklch(64.1% 0.275 312.9);oklch(65% 0.238 17.9);oklch(74.7% 0.18 57.4);oklch(64.1% 0.275 312.9)" keyTimes="0;0.33;0.66;1" keySplines="0.42 0 0.58 1;0.42 0 0.58 1;0.42 0 0.58 1" calcMode="spline" dur="3s" repeatCount="indefinite"/>
              </stop>
              <stop offset="45%" stop-color="oklch(65% 0.238 17.9)">
                <animate attributeName="stop-color" values="oklch(65% 0.238 17.9);oklch(74.7% 0.18 57.4);oklch(64.1% 0.275 312.9);oklch(65% 0.238 17.9)" keyTimes="0;0.33;0.66;1" keySplines="0.42 0 0.58 1;0.42 0 0.58 1;0.42 0 0.58 1" calcMode="spline" dur="3s" repeatCount="indefinite"/>
              </stop>
              <stop offset="100%" stop-color="oklch(74.7% 0.18 57.4)">
                <animate attributeName="stop-color" values="oklch(74.7% 0.18 57.4);oklch(64.1% 0.275 312.9);oklch(65% 0.238 17.9);oklch(74.7% 0.18 57.4)" keyTimes="0;0.33;0.66;1" keySplines="0.42 0 0.58 1;0.42 0 0.58 1;0.42 0 0.58 1" calcMode="spline" dur="3s" repeatCount="indefinite"/>
              </stop>
            </linearGradient>
          </defs>
          <path
            class="home-logo-fill"
            fill-rule="evenodd"
            d="M34,0 L34,34 L0,34 L0,0 L34,0 Z M19.4754653,6 L14.4686971,6 L6,28 L11.7884941,28 L13.2402707,23.4972527 L20.7038917,23.4972527 L22.1556684,28 L28,28 L19.4754653,6 Z"
          />
        </svg>
      </a>
      <h1 id="intro-title" class="mb-6 max-w-[9ch] text-balance font-serif text-[3.6rem] leading-[0.92] text-ink md:text-[4.85rem]">
        {name}
      </h1>
      <p class="max-w-[38rem] text-balance font-serif text-[1.28rem] leading-[1.28] text-ink md:text-[1.48rem]">{summary}</p>
      <nav class="mt-7 flex flex-wrap gap-x-6 gap-y-3" aria-label="Contact links">
        {
          links.map((link) => {
            const icon = iconByLabel[link.label];
            const gradientId = `contact-icon-${link.label.toLowerCase()}-gradient`;

            return (
              <a class="contact-link" href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined} aria-label={link.label}>
                <span class="contact-icon-wrap" set:html={withIconGradient(icon, gradientId)} />
              </a>
            );
          })
        }
      </nav>
    </header>

    <section class="pb-10 pt-6 md:pb-12 md:pt-8" aria-labelledby="experience-title">
      <h2 id="experience-title" class="mb-8 text-balance font-serif text-[2.4rem] leading-tight text-ink md:text-[3rem]">Experience</h2>
      <ol class="space-y-9">
        {
          roles.map((item) => (
            <li>
              <div class="max-w-[38rem]">
                <h3 class="mb-1 text-balance font-serif text-[1.75rem] leading-tight text-ink">
                  {item.url ? (
                    <a class="gradient-link" href={item.url} target="_blank" rel="noreferrer" data-label={item.company}>
                      {item.company}
                    </a>
                  ) : (
                    item.company
                  )}
                </h3>
                <p class="mb-1 text-balance text-[0.9rem] leading-snug text-muted">{item.role}</p>
                <p class="mb-2 text-balance text-[0.8rem] leading-snug text-muted">{item.period} · {item.location}</p>
                {item.descriptionHtml ? <p class="text-balance" set:html={item.descriptionHtml} /> : <p class="text-balance">{item.description}</p>}
              </div>
            </li>
          ))
        }
      </ol>
    </section>

  </main>
</BaseLayout>
